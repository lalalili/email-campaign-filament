{
    "name": "lalalili/email-campaign-filament",
    "description": "Filament v4 admin UI layer for the email-campaign package.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "lalalili/email-campaign": "@dev",
        "filament/filament": "^4.0",
        "filament/forms": "^4.0",
        "filament/schemas": "^4.0",
        "filament/tables": "^4.0",
        "filament/actions": "^4.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "pestphp/pest-plugin-livewire": "^3.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Lalalili\\EmailCampaignFilament\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lalalili\\EmailCampaignFilament\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lalalili\\EmailCampaignFilament\\EmailCampaignFilamentServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "pest",
        "format": "pint"
    }
}
